import random

def buscar_max_min_multiplos3_rec(arreglo, indice):
    if indice == len(arreglo):
        return None, None
    
    max_resto, min_resto = buscar_max_min_multiplos3_rec(arreglo, indice + 1)
    
    elem_actual = arreglo[indice]
    

    if elem_actual % 3 == 0:
        if max_resto is None:
            return elem_actual, elem_actual
        else:
            nuevo_max = elem_actual if elem_actual > max_resto else max_resto
            nuevo_min = elem_actual if elem_actual < min_resto else min_resto
            return nuevo_max, nuevo_min
    else:
        return max_resto, min_resto

def calcular_promedio_max_min(arreglo):
    maximo, minimo = buscar_max_min_multiplos3_rec(arreglo, 0)
    
    if maximo is None or minimo is None:
        return "No se encontraron números múltiplos de 3 en el arreglo."
    
    promedio = (maximo + minimo) / 2
    return promedio

if __name__ == "__main__":
    tamano = int(input("Ingrese el tamaño del arreglo: "))
    
    # 2. Se llena con números aleatorios de entre 2 a 4 cifras (de 10 a 9999)
    arreglo_usuario = [random.randint(10, 9999) for _ in range(tamano)]
    print("\nArreglo generado aleatoriamente:")
    print(arreglo_usuario)
    
    
    print("\n--- Resultado del Arreglo Usuario ---")
    resultado = calcular_promedio_max_min(arreglo_usuario)
    print(f"El promedio entre el máximo y mínimo múltiplo de 3 es: {resultado}")
